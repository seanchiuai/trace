# Convex (auto-populated by `npx convex dev`)
VITE_CONVEX_URL=

# ──────────────────────────────────────────────────
# The following keys are set in the Convex dashboard
# (Settings → Environment Variables), NOT in this file.
# Listed here for reference only.
# ──────────────────────────────────────────────────

# Required
# ANTHROPIC_API_KEY=sk-ant-...
# BROWSER_USE_API_KEY=...
# BRAVE_API_KEY=...

# Optional — geolocation & image search
# PICARTA_API_KEY=...
# GEOSPY_API_KEY=...
# SERPAPI_API_KEY=...

# Optional — extreme mode
# WHITEPAGES_API_KEY=...
# INTELX_API_KEY=...

# Optional — Maigret sidecar (defaults to http://localhost:8000)
# MAIGRET_SIDECAR_URL=http://localhost:8000
